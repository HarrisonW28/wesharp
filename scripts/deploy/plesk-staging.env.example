# Copy on the Plesk server (outside git), e.g. /etc/wesharp/staging-deploy.env
# chmod 600 — never commit real values.

# Git checkout root (clone of github.com/HarrisonW28/wesharp)
WESHARP_APP_ROOT=/var/www/vhosts/staging.wesharp.co.uk/httpdocs/wesharp

# Branch deployed to staging
WESHARP_DEPLOY_BRANCH=staging

# Staging URLs (smoke checks)
WESHARP_STAGING_API_URL=https://api-staging.wesharp.co.uk
WESHARP_STAGING_FRONTEND_URL=https://staging.wesharp.co.uk

# PHP / Composer (Plesk often uses versioned paths)
WESHARP_PHP_BIN=/opt/plesk/php/8.3/bin/php
WESHARP_COMPOSER_BIN=/usr/local/bin/composer

# Optional: skip git pull when Plesk Git extension already updated the tree
# WESHARP_SKIP_GIT_PULL=1

# Optional: maintenance mode during migrate
# WESHARP_USE_MAINTENANCE=1

# Frontend restart after build (pick one approach)
# Plesk Node.js extension domain name:
WESHARP_PLESK_NODE_DOMAIN=staging.wesharp.co.uk
# Or explicit command (PM2 example):
# WESHARP_FRONTEND_RESTART_CMD='pm2 restart wesharp-staging-frontend'

# Optional PHP-FPM reload after backend deploy
# WESHARP_PHP_FPM_SERVICE=plesk-php83-fpm
