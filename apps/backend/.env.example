APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Production: set APP_ENV=production, APP_DEBUG=false; run `php artisan migrate --force` without --seed
# unless you add a dedicated non-demo seeder. `DatabaseSeeder` skips demo data when APP_ENV=production.

# Customer email portal links (defaults to APP_URL)
FRONTEND_URL=http://localhost:3000

# Subscription customer emails (scheduled — see bootstrap/app.php and config/wesharp.php)
# SUBSCRIPTION_RENEWAL_REMINDER_DAYS=7
# SUBSCRIPTION_PERIOD_SUMMARY_DAYS_BEFORE_RENEWAL=1

#
# Frontend (Browser) — tightening CORS in production (see docs/security/auth-sso.md)
#
FRONTEND_ORIGIN=http://localhost:3000
# Optional: extra comma-separated SPA origins (e.g. Vercel preview URLs) for config/cors.php
# CORS_ALLOWED_ORIGINS=https://wesharp.vercel.app,https://wesharp-git-main-acme.vercel.app

#
# Clerk (backend verifies JWT Bearer tokens from the SPA and syncs first-time Clerk users via API)
#
CLERK_SECRET_KEY=
# JWKS URI from Clerk Dashboard (API keys → show JWT / JWKS URLs)
CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json
CLERK_JWT_ISSUER=https://your-instance.clerk.accounts.dev
# Optional: constrain session JWT audiences (JWT `aud`/`azp` depending on Clerk version)
# Optional. Must match session JWT `aud` or `azp` from Clerk if set; leave unset to skip.
# CLERK_JWT_AUDIENCE=
CLERK_API_BASE=https://api.clerk.com/v1
# Svix signing secret from Clerk → Webhooks (whsec_…). Required for POST /api/webhooks/clerk.
CLERK_WEBHOOK_SIGNING_SECRET=
# New Clerk signups only: customer_owner (recommended) or customer_staff. Internal/staff role values are ignored.
CLERK_DEFAULT_USER_ROLE=customer_owner
CLERK_DEFAULT_USER_STATUS=active

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
# Scheduler (cron): invoke `php artisan schedule:run` every minute in production.
# Optional Redis for queue/cache: set QUEUE_CONNECTION=redis then tune REDIS_* and config/queue.php.
# Optional Redis cache: CACHE_STORE=redis (see config/cache.php REDIS_* env keys).

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

#
# Stripe — see docs/integrations/stripe.md (never commit real secrets).
#
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Optional until Stripe.js / Checkout client needs it (pk_test_* / pk_live_*).
STRIPE_PUBLIC_KEY=
# Hosted Checkout — keep false until Checkout Session API + webhooks are verified (Sprint 19+).
STRIPE_HOSTED_CHECKOUT_ENABLED=false
# When hosted checkout is true, success/cancel URLs are required before offering a session.
# Example (adjust host): https://app.example.com/account/invoices/{CHECKOUT_SESSION_ID}/paid
STRIPE_CHECKOUT_SUCCESS_URL=
STRIPE_CHECKOUT_CANCEL_URL=
# Must be true to use sk_live_* keys in app guards (default blocks live).
STRIPE_ALLOW_LIVE=false

#
# Invoice documents (optional — see config/invoices.php)
#
# INVOICE_ISSUER_NAME=WeSharp
# INVOICE_ISSUER_ADDRESS="123 Example Street\nManchester\nUK"
# INVOICE_ISSUER_EMAIL=accounts@example.com
# INVOICE_ISSUER_PHONE=
# INVOICE_ISSUER_VAT_NUMBER=
# INVOICE_DEFAULT_PAYMENT_FOOTER="Pay by bank transfer. Contact us for bank details."
# Subscription invoice generation (Sprint 9 — default off; see docs/product/subscription-invoices.md)
# INVOICE_SUBSCRIPTION_GENERATION_ENABLED=false
