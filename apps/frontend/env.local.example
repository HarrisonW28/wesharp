# Copy to env.local — never commit secrets
#
# Laravel API reachable from the browser (no trailing slash)
NEXT_PUBLIC_API_ORIGIN=http://localhost:8000

# Clerk (Dashboard → API keys → Publishable key)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Builds / CI-only: Clerk validates key structure — use real keys locally.
# Structural placeholder decoding to `aaa-bbb-12.clerk.accounts.dev` (still not wired to YOUR instance):
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_YWFhLWJiYi0xMi5jbGVyay5hY2NvdW50cy5kZXYk

