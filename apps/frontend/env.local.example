# Copy to env.local — never commit secrets
#
# Laravel API reachable from the browser AND from the Next.js server (SSR) — no trailing slash.
# Required for public marketing pages and /api/public/site-content; if unset, copy falls back to built-in defaults only.
NEXT_PUBLIC_API_ORIGIN=http://localhost:8000

# Clerk (Dashboard → API keys → Publishable key)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# If unset at build time, the app falls back to a structural pk_test_* placeholder so `next build` succeeds.
# Structural placeholder decoding to `aaa-bbb-12.clerk.accounts.dev` (still not wired to YOUR instance):
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_YWFhLWJiYi0xMi5jbGVyay5hY2NvdW50cy5kZXYk

# Stripe publishable key only (optional — Sprint 7.4+). Never put secret keys here.
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
#
# Redirect URLs for Stripe Checkout live in the Laravel API (.env): STRIPE_CHECKOUT_SUCCESS_URL / STRIPE_CHECKOUT_CANCEL_URL
# (see docs/integrations/stripe.md). Do not put webhook secrets in the browser.
